<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:paddingHorizontal="48dp">

    <!-- ======================= top bar ======================= -->
    <ImageView
        android:id="@+id/brandMark"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_mark"
        android:padding="9dp"
        android:importantForAccessibility="no"
        android:src="@drawable/ic_wave"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/brandTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="@string/app_name"
        android:textColor="@color/ink"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/brandTag"
        app:layout_constraintEnd_toStartOf="@id/pasteBtn"
        app:layout_constraintStart_toEndOf="@id/brandMark"
        app:layout_constraintTop_toTopOf="@id/brandMark"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/brandTag"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="@string/tagline"
        android:textColor="@color/ink_dim"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@id/brandMark"
        app:layout_constraintEnd_toStartOf="@id/pasteBtn"
        app:layout_constraintStart_toEndOf="@id/brandMark"
        app:layout_constraintTop_toBottomOf="@id/brandTitle" />

    <ImageButton
        android:id="@+id/pasteBtn"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/cd_paste"
        android:src="@drawable/ic_paste"
        app:layout_constraintBottom_toBottomOf="@id/brandMark"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/brandMark" />

    <!-- ======================= reading surface ======================= -->
    <ScrollView
        android:id="@+id/readerScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_card"
        android:fadeScrollbars="true"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/dock"
        app:layout_constraintTop_toBottomOf="@id/brandMark">

        <TextView
            android:id="@+id/readerText"
            android:layout_gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:lineSpacingMultiplier="1.55"
            android:padding="28dp"
            android:textColor="@color/ink"
            android:textIsSelectable="true"
            android:maxWidth="560dp"
            android:textSize="19sp"
            tools:text="Reading text appears here." />
    </ScrollView>

    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_card"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="28dp"
        android:layout_marginTop="14dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/dock"
        app:layout_constraintTop_toBottomOf="@id/brandMark"
        tools:visibility="visible">

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_mark"
            android:importantForAccessibility="no"
            android:padding="14dp"
            android:src="@drawable/ic_wave" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/empty_title"
            android:textColor="@color/ink"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:maxWidth="300dp"
            android:text="@string/empty_body"
            android:textColor="@color/ink_dim"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/pasteBig"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/amber"
            android:paddingHorizontal="28dp"
            android:text="@string/paste_text"
            android:textColor="@color/on_amber"
            android:textSize="15sp"
            android:textStyle="bold"
            app:cornerRadius="24dp" />
    </LinearLayout>

    <!-- ======================= control dock ======================= -->
    <LinearLayout
        android:id="@+id/dock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingBottom="10dp"
        app:layout_constraintBottom_toTopOf="@id/bubbleRow">

        <TextView
            android:id="@+id/progressPct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:textColor="@color/ink_dim"
            android:textSize="11sp"
            tools:text="42%" />

        <SeekBar
            android:id="@+id/progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@null"
            android:maxHeight="3dp"
            android:minHeight="3dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:progressDrawable="@drawable/seekbar_progress"
            android:splitTrack="false"
            android:thumb="@drawable/seekbar_thumb" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/voiceChip"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip"
                android:contentDescription="@string/cd_voice"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_wave" />

                <TextView
                    android:id="@+id/voiceChipLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="7dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/ink"
                    android:textSize="13sp"
                    tools:text="English (US) · Voice II" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="6dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_chevron_down" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/speedChip"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip"
                android:contentDescription="@string/cd_speed"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp">

                <TextView
                    android:id="@+id/speedChipLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/ink"
                    android:textSize="13sp"
                    tools:text="1.0×" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="6dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_chevron_down" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp">

            <ImageButton
                android:id="@+id/backBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="36dp"
                android:background="@drawable/bg_side_btn"
                android:contentDescription="@string/cd_back_sentence"
                android:src="@drawable/ic_back_sentence" />

            <ImageButton
                android:id="@+id/playBtn"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_play"
                android:contentDescription="@string/cd_play"
                android:elevation="6dp"
                android:src="@drawable/ic_play" />

            <ImageButton
                android:id="@+id/stopBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="36dp"
                android:background="@drawable/bg_side_btn"
                android:contentDescription="@string/cd_stop"
                android:src="@drawable/ic_stop" />
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bubbleRow"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_chip"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        app:layout_constraintBottom_toTopOf="@id/hint">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_wave" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bubble_title"
                android:textColor="@color/ink"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/bubbleSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/bubble_sub_off"
                android:textColor="@color/ink_dim"
                android:textSize="11sp" />
        </LinearLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/bubbleSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/cd_bubble"
            app:thumbTint="@color/ink"
            app:trackTint="@color/amber_soft" />
    </LinearLayout>

    <TextView
        android:id="@+id/hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="8dp"
        android:paddingBottom="10dp"
        android:text="@string/hint_selection"
        android:textColor="@color/ink_dim"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
